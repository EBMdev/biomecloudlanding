---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const f = t.footer;
const isEs = lang === 'es';
---

<footer class="relative z-10 border-t border-white/5 bg-bg-900/80 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8 mb-12">

      <!-- Brand col -->
      <div class="col-span-2">
        <a href={isEs ? '/es' : '/'} class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-500 to-blue-700 rounded-lg flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="3" fill="white"/>
              <circle cx="4" cy="8" r="2" fill="rgba(255,255,255,0.6)"/>
              <circle cx="20" cy="8" r="2" fill="rgba(255,255,255,0.6)"/>
              <circle cx="4" cy="16" r="2" fill="rgba(255,255,255,0.6)"/>
              <circle cx="20" cy="16" r="2" fill="rgba(255,255,255,0.6)"/>
              <line x1="9" y1="10.5" x2="6" y2="9" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <line x1="15" y1="10.5" x2="18" y2="9" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <line x1="9" y1="13.5" x2="6" y2="15" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <line x1="15" y1="13.5" x2="18" y2="15" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
            </svg>
          </div>
          <span class="text-white font-bold text-lg tracking-tight">BiomeCloud</span>
        </a>
        <p class="text-gray-500 text-sm leading-relaxed max-w-xs">{f.tagline}</p>

        <!-- Status badge -->
        <div class="mt-4 inline-flex items-center gap-2 bg-emerald-500/5 border border-emerald-500/20 rounded-full px-3 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-xs text-emerald-400 font-medium">All systems operational</span>
        </div>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">{f.company.title}</h4>
        <ul class="space-y-2.5">
          {f.company.links.map(link => (
            <li><a href="#" class="text-sm text-gray-500 hover:text-white transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">{f.services.title}</h4>
        <ul class="space-y-2.5">
          {f.services.links.map(link => (
            <li><a href="#" class="text-sm text-gray-500 hover:text-white transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">{f.resources.title}</h4>
        <ul class="space-y-2.5">
          {f.resources.links.map(link => (
            <li><a href="#" class="text-sm text-gray-500 hover:text-white transition-colors">{link}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">{f.legal.title}</h4>
        <ul class="space-y-2.5">
          {f.legal.links.map(link => (
            <li><a href="#" class="text-sm text-gray-500 hover:text-white transition-colors">{link}</a></li>
          ))}
        </ul>

        <!-- Language switcher -->
        <div class="mt-6">
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">{f.lang}</h4>
          <div class="flex gap-2">
            <a
              href="/"
              class={`text-xs px-3 py-1.5 rounded-lg border transition-colors ${!isEs ? 'bg-blue-600/20 border-blue-500/30 text-blue-400' : 'border-white/10 text-gray-500 hover:text-white hover:border-white/20'}`}
            >
              EN
            </a>
            <a
              href="/es"
              class={`text-xs px-3 py-1.5 rounded-lg border transition-colors ${isEs ? 'bg-blue-600/20 border-blue-500/30 text-blue-400' : 'border-white/10 text-gray-500 hover:text-white hover:border-white/20'}`}
            >
              ES
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600">{f.copyright}</p>
      <div class="flex items-center gap-4">
        <!-- Discord -->
        <a href="#" class="text-gray-600 hover:text-white transition-colors" aria-label="Discord">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.036.055a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
          </svg>
        </a>
        <!-- Twitter/X -->
        <a href="#" class="text-gray-600 hover:text-white transition-colors" aria-label="X / Twitter">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <!-- GitHub -->
        <a href="#" class="text-gray-600 hover:text-white transition-colors" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
