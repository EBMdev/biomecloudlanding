---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEs = lang === 'es';
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={isEs ? '/es' : '/'} class="flex items-center gap-2.5 group">
        <div class="relative w-8 h-8">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-500 to-blue-700 rounded-lg"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="3" fill="white"/>
              <circle cx="4" cy="8" r="2" fill="rgba(255,255,255,0.6)"/>
              <circle cx="20" cy="8" r="2" fill="rgba(255,255,255,0.6)"/>
              <circle cx="4" cy="16" r="2" fill="rgba(255,255,255,0.6)"/>
              <circle cx="20" cy="16" r="2" fill="rgba(255,255,255,0.6)"/>
              <line x1="9" y1="10.5" x2="6" y2="9" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <line x1="15" y1="10.5" x2="18" y2="9" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <line x1="9" y1="13.5" x2="6" y2="15" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
              <line x1="15" y1="13.5" x2="18" y2="15" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
            </svg>
          </div>
        </div>
        <span class="text-white font-bold text-lg tracking-tight group-hover:text-blue-400 transition-colors">BiomeCloud</span>
      </a>

      <!-- Center nav links -->
      <div class="hidden md:flex items-center gap-1">
        <a href="#services" class="nav-link">{t.nav.minecraft}</a>
        <a href="#bot-plans" class="nav-link">{t.nav.discord}</a>
        <a href="#mc-plans" class="nav-link">{t.nav.pricing}</a>
        <a href="#" class="nav-link">{t.nav.docs}</a>
        <a href="#" class="nav-link">
          <span class="flex items-center gap-1.5">
            {t.nav.status}
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block" style="animation: pulse 4s cubic-bezier(0.4,0,0.6,1) infinite;"></span>
          </span>
        </a>
      </div>

      <!-- Right actions -->
      <div class="hidden md:flex items-center gap-3">
        <a href={isEs ? '/' : '/es'} class="text-sm text-gray-400 hover:text-white transition-colors px-2 py-1 rounded-md hover:bg-white/5">
          {isEs ? 'EN' : 'ES'}
        </a>
        <a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">{t.nav.login}</a>
        <a href="#mc-plans" class="btn-cta text-sm py-2 px-4">{t.nav.cta}</a>
      </div>

      <!-- Mobile menu button -->
      <button class="md:hidden text-gray-400 hover:text-white p-2" id="mobile-menu-btn" aria-label="Toggle menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden border-t border-white/5" id="mobile-menu" style="background: rgba(15,23,42,0.95); backdrop-filter: blur(20px);">
    <div class="px-4 py-4 flex flex-col gap-2">
      <a href="#services" class="mobile-nav-link">{t.nav.minecraft}</a>
      <a href="#bot-plans" class="mobile-nav-link">{t.nav.discord}</a>
      <a href="#mc-plans" class="mobile-nav-link">{t.nav.pricing}</a>
      <a href="#" class="mobile-nav-link">{t.nav.docs}</a>
      <div class="pt-2 border-t border-white/10 flex gap-3 items-center">
        <a href={isEs ? '/' : '/es'} class="text-sm text-gray-400">{isEs ? 'English' : 'Español'}</a>
        <a href="#" class="text-sm text-gray-300">{t.nav.login}</a>
        <a href="#mc-plans" class="btn-cta text-sm py-1.5 px-3">{t.nav.cta}</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    font-size: 0.875rem;
    color: #9CA3AF;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    transition: color 0.2s, background-color 0.2s;
    text-decoration: none;
  }
  .nav-link:hover {
    color: #ffffff;
    background-color: rgba(255,255,255,0.05);
  }
  .mobile-nav-link {
    display: block;
    font-size: 1rem;
    color: #D1D5DB;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: color 0.2s, background-color 0.2s;
    text-decoration: none;
  }
  .mobile-nav-link:hover {
    color: #ffffff;
    background-color: rgba(255,255,255,0.05);
  }
  .btn-cta {
    background-color: #2563EB;
    color: #ffffff;
    font-weight: 600;
    border-radius: 0.5rem;
    transition: background-color 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }
  .btn-cta:hover {
    background-color: #3B82F6;
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) navbar?.classList.add('scrolled');
    else navbar?.classList.remove('scrolled');
  });

  mobileBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
  });
</script>
