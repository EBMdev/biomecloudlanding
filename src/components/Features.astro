---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const f = t.features;

const icons = [
  // Lightning Fast
  `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
  // DDoS Shield
  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  // Instant Deploy
  `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  // Control Panel
  `<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>`,
  // Backups
  `<polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/>`,
  // Support
  `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
];
---

<section id="features" class="relative z-10 py-24">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-950/20 rounded-full blur-[120px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">{f.title}</h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">{f.subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {f.items.map((item, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} group relative bg-bg-800/40 hover:bg-bg-800/70 border border-white/5 hover:border-blue-500/20 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 overflow-hidden`}>
          <!-- Corner glow -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-600/5 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity -translate-y-1/2 translate-x-1/2"></div>

          <div class="relative">
            <div class="w-11 h-11 bg-blue-600/10 group-hover:bg-blue-600/20 border border-blue-500/10 group-hover:border-blue-500/30 rounded-xl flex items-center justify-center mb-4 transition-all duration-300">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i]}></svg>
            </div>

            <h3 class="text-base font-semibold text-white mb-2 group-hover:text-blue-100 transition-colors">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed group-hover:text-gray-400 transition-colors">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
