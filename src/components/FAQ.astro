---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const faq = t.faq;
---

<section id="faq" class="relative z-10 py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">{faq.title}</h2>
      <p class="text-gray-400 text-lg">{faq.subtitle}</p>
    </div>

    <div class="space-y-3">
      {faq.items.map((item, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} faq-item border border-white/5 rounded-2xl overflow-hidden bg-bg-800/30 hover:border-white/10 transition-colors`} data-index={i}>
          <button
            class="faq-trigger w-full flex items-center justify-between gap-4 p-5 text-left"
            aria-expanded="false"
          >
            <span class="font-medium text-white text-sm sm:text-base">{item.q}</span>
            <span class="faq-icon flex-shrink-0 w-7 h-7 rounded-full bg-white/5 flex items-center justify-center transition-transform duration-300">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </button>
          <div class="faq-body hidden px-5 pb-5">
            <p class="text-gray-400 text-sm leading-relaxed">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const body = item.querySelector('.faq-body') as HTMLElement;
      const icon = item.querySelector('.faq-icon') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll('.faq-trigger').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        const i = b.closest('.faq-item') as HTMLElement;
        i.querySelector('.faq-body')?.classList.add('hidden');
        (i.querySelector('.faq-icon') as HTMLElement).style.transform = '';
      });

      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        body.classList.remove('hidden');
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
