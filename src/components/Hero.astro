---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const d = t.hero.dashboard;
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Background gradients -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-600/20 rounded-full blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-blue-800/15 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay:2s"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-950/30 rounded-full blur-[150px]"></div>
    <!-- Grid -->
    <div class="absolute inset-0 bg-grid-pattern opacity-40"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text -->
      <div class="flex flex-col gap-6">
        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-2 self-start">
          <span class="flex items-center gap-2 bg-blue-600/10 border border-blue-500/20 text-blue-400 text-sm font-medium px-4 py-1.5 rounded-full">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
            {t.hero.badge}
          </span>
        </div>

        <!-- Headline -->
        <h1 class="reveal reveal-delay-1 text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.05] tracking-tight">
          {t.hero.headline.split(' ').slice(0, 3).join(' ')}
          <span class="block bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent">
            {t.hero.headline.split(' ').slice(3).join(' ')}
          </span>
        </h1>

        <!-- Subheadline -->
        <p class="reveal reveal-delay-2 text-gray-400 text-lg leading-relaxed max-w-lg">
          {t.hero.subheadline}
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
          <a href="#mc-plans" class="group relative inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-200 shadow-lg shadow-blue-600/25 hover:shadow-blue-500/40 hover:-translate-y-0.5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            </svg>
            {t.hero.cta_primary}
          </a>
          <a href="#bot-plans" class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-200 hover:-translate-y-0.5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.44-4z"/>
              <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.44-4z"/>
            </svg>
            {t.hero.cta_secondary}
          </a>
        </div>

        <!-- Trust signals -->
        <div class="reveal reveal-delay-4 flex items-center gap-4 text-sm text-gray-500">
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            No credit card required
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Deploy in 60 seconds
          </span>
          <span class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Cancel anytime
          </span>
        </div>
      </div>

      <!-- Right: Dashboard Mockup -->
      <div class="reveal reveal-delay-2 relative">
        <div class="animate-float">
          <!-- Outer glow -->
          <div class="absolute -inset-4 bg-blue-600/10 rounded-3xl blur-2xl"></div>

          <!-- Dashboard panel -->
          <div class="relative bg-bg-800/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
            <!-- Top bar -->
            <div class="flex items-center justify-between px-4 py-3 bg-bg-900/60 border-b border-white/5">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
              </div>
              <span class="text-xs text-gray-500 font-mono">{d.title}</span>
              <div class="w-16"></div>
            </div>

            <div class="p-5 grid grid-cols-2 gap-3">
              <!-- MC Status -->
              <div class="col-span-2 bg-bg-900/60 rounded-xl p-4 border border-white/5">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-xs text-gray-500 uppercase tracking-wider font-medium">{d.mc_status}</span>
                  <span class="flex items-center gap-1.5 text-xs text-emerald-400 font-medium">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                    {d.online}
                  </span>
                </div>
                <div class="grid grid-cols-3 gap-3">
                  <div class="text-center">
                    <div class="text-2xl font-bold text-white">247</div>
                    <div class="text-xs text-gray-500 mt-0.5">{d.mc_players}</div>
                  </div>
                  <div class="text-center border-x border-white/5">
                    <div class="text-2xl font-bold text-blue-400">18%</div>
                    <div class="text-xs text-gray-500 mt-0.5">{d.cpu}</div>
                  </div>
                  <div class="text-center">
                    <div class="text-2xl font-bold text-purple-400">4.2GB</div>
                    <div class="text-xs text-gray-500 mt-0.5">{d.ram}</div>
                  </div>
                </div>
                <!-- RAM bar -->
                <div class="mt-3">
                  <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
                    <div class="h-full w-[35%] bg-gradient-to-r from-blue-600 to-blue-400 rounded-full animate-pulse-slow"></div>
                  </div>
                </div>
              </div>

              <!-- CPU chart simulation -->
              <div class="bg-bg-900/60 rounded-xl p-3 border border-white/5">
                <div class="text-xs text-gray-500 mb-2 uppercase tracking-wider">CPU Load</div>
                <div class="flex items-end gap-0.5 h-10">
                  {[40, 65, 45, 80, 55, 70, 45, 60, 50, 75, 48, 62].map((h) => (
                    <div
                      class="flex-1 rounded-sm bg-gradient-to-t from-blue-700 to-blue-400 opacity-80"
                      style={`height: ${h}%`}
                    ></div>
                  ))}
                </div>
              </div>

              <!-- Bot status -->
              <div class="bg-bg-900/60 rounded-xl p-3 border border-white/5">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs text-gray-500 uppercase tracking-wider">{d.bot_uptime}</span>
                  <span class="flex items-center gap-1 text-xs text-emerald-400">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                    {d.running}
                  </span>
                </div>
                <div class="text-xl font-bold text-white">99.98%</div>
                <div class="text-xs text-gray-500 mt-0.5">30 day avg</div>
                <div class="mt-2 h-1 bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full w-[99.98%] bg-gradient-to-r from-emerald-700 to-emerald-400 rounded-full"></div>
                </div>
              </div>

              <!-- Connections -->
              <div class="col-span-2 bg-bg-900/60 rounded-xl p-3 border border-white/5">
                <div class="flex items-center justify-between">
                  <span class="text-xs text-gray-500 uppercase tracking-wider">{d.connections}</span>
                  <span class="text-xs font-mono text-blue-400">+12 this hour</span>
                </div>
                <div class="flex items-center gap-3 mt-2">
                  <div class="text-2xl font-bold text-white">1,847</div>
                  <div class="flex-1 flex gap-0.5 items-center">
                    {[60,80,55,90,70,85,65,92,75,88,72,95].map((h) => (
                      <div class="flex-1 rounded-sm bg-blue-500/30 border border-blue-500/20" style={`height: ${h * 0.3}px`}></div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating badges -->
          <div class="absolute -top-4 -right-4 bg-emerald-500/10 border border-emerald-500/30 rounded-xl px-3 py-2 backdrop-blur-sm">
            <div class="text-xs text-emerald-400 font-medium">✓ DDoS Protected</div>
          </div>
          <div class="absolute -bottom-4 -left-4 bg-blue-600/10 border border-blue-500/30 rounded-xl px-3 py-2 backdrop-blur-sm">
            <div class="text-xs text-blue-400 font-medium">⚡ AMD Ryzen</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-bg-900 to-transparent z-10"></div>
</section>
