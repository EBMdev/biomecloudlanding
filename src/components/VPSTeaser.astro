---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const v = t.vps;
---

<section class="relative z-10 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal relative rounded-2xl overflow-hidden border border-white/5 bg-bg-800/20 p-8">
      <div class="absolute top-0 right-0 w-80 h-40 bg-blue-950/20 rounded-full blur-[80px] pointer-events-none"></div>
      <div class="relative flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-bg-700/60 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/>
              <line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-semibold bg-gray-700/50 text-gray-400 border border-gray-600/30 px-2.5 py-0.5 rounded-full uppercase tracking-wider">{v.badge}</span>
            </div>
            <h3 class="text-base font-semibold text-white">{v.title}</h3>
            <p class="text-sm text-gray-500 mt-0.5">{v.subtitle}</p>
          </div>
        </div>
        <a
          href="#"
          class="flex-shrink-0 text-sm font-medium text-gray-400 hover:text-white border border-white/10 hover:border-white/20 px-4 py-2 rounded-xl transition-all duration-200"
        >
          {v.cta} →
        </a>
      </div>
    </div>
  </div>
</section>
