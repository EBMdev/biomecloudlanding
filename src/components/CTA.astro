---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cta = t.cta;
---

<section class="relative z-10 py-32 overflow-hidden">
  <!-- Animated gradient background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-950 via-bg-800 to-bg-900"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] bg-blue-600/20 rounded-full blur-[100px] animate-pulse-slow"></div>
    <div class="absolute top-0 left-0 w-full h-full bg-grid-pattern opacity-30"></div>
    <!-- Animated glowing orbs -->
    <div class="absolute top-10 left-1/4 w-4 h-4 bg-blue-500 rounded-full blur-sm opacity-60 animate-float"></div>
    <div class="absolute bottom-10 right-1/4 w-3 h-3 bg-blue-400 rounded-full blur-sm opacity-40 animate-float" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/2 right-1/3 w-2 h-2 bg-cyan-400 rounded-full blur-sm opacity-50 animate-float" style="animation-delay: 4s;"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="reveal">
      <!-- Node network decoration -->
      <div class="flex items-center justify-center gap-2 mb-8 opacity-40">
        {[...Array(7)].map((_, i) => (
          <div class="flex items-center gap-2">
            <div class={`rounded-full bg-blue-400 ${i === 3 ? 'w-3 h-3' : 'w-1.5 h-1.5'} ${i === 3 ? 'opacity-100' : 'opacity-60'}`}></div>
            {i < 6 && <div class="w-6 h-px bg-blue-600/50"></div>}
          </div>
        ))}
      </div>

      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
        {cta.title}
      </h2>
      <p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto">
        {cta.subtitle}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#mc-plans"
          class="group inline-flex items-center gap-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200 shadow-2xl shadow-blue-600/30 hover:shadow-blue-500/50 hover:-translate-y-1 text-base"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          </svg>
          {cta.mc}
        </a>
        <a
          href="#bot-plans"
          class="inline-flex items-center gap-2.5 bg-white/10 hover:bg-white/15 border border-white/20 hover:border-white/30 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200 hover:-translate-y-1 text-base"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.44-4z"/>
            <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.44-4z"/>
          </svg>
          {cta.bot}
        </a>
      </div>
    </div>
  </div>
</section>
