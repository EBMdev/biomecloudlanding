---
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { ...t.stats.uptime, icon: 'uptime' },
  { ...t.stats.setup, icon: 'bolt' },
  { ...t.stats.support, icon: 'support' },
  { ...t.stats.nodes, icon: 'globe' },
];
---

<section class="relative z-10 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {stats.map((stat, i) => (
        <div class={`reveal reveal-delay-${i + 1} group relative bg-bg-800/40 hover:bg-bg-800/70 border border-white/5 hover:border-blue-500/20 rounded-2xl p-6 text-center transition-all duration-300 hover:-translate-y-1 overflow-hidden`}>
          <!-- Subtle glow on hover -->
          <div class="absolute inset-0 bg-gradient-to-b from-blue-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl"></div>

          <div class="relative">
            <!-- Icon -->
            <div class="w-10 h-10 mx-auto mb-3 bg-blue-600/10 rounded-xl flex items-center justify-center group-hover:bg-blue-600/20 transition-colors">
              {stat.icon === 'uptime' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                </svg>
              )}
              {stat.icon === 'bolt' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              )}
              {stat.icon === 'support' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
              )}
              {stat.icon === 'globe' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="2" y1="12" x2="22" y2="12"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              )}
            </div>

            <div class="text-3xl font-black text-white mb-1">{stat.value}</div>
            <div class="text-sm text-gray-500">{stat.label}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
